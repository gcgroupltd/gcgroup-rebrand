{% assign slides = '' | split: ',' %}
{% assign get_to_know_count = 0 %}

{% if section.settings.data == 'general' %}
  {% assign slides = shop.metaobjects.get_to_know_slides.values | sort: 'order' %}
  {% assign get_to_know_count = slides.size %}
{% else %}
  {% assign main_menu = linklists['main-menu'].links %}
  {% assign current_category = null %}

  {% for category in main_menu %}
    {% for sublink in category.links %}
      {% for child in sublink.links %}
        {% if child.type == 'collection_link' and child.object.handle == collection.handle %}
          {% assign current_category = category %}
        {% endif %}
      {% endfor %}
    {% endfor %}
  {% endfor %}

  {% if current_category %}
    {% for sublink in current_category.links %}
      {% for child in sublink.links %}
        {% if child.type == 'collection_link' and child.object %}
          {% assign temp_array = child.object.handle | split: ',' %}

          {% for handle in temp_array %}
            {% if handle != collection.handle %}
              {% assign slides = slides | concat: temp_array %}
            {% endif %}
          {% endfor %}
        {% endif %}
      {% endfor %}
    {% endfor %}
  {% endif %}

  {% if current_category == null %}
    {% assign current_type = '' %}

    {% assign collection_title_down = collection.title | downcase %}

    {% if collection_title_down contains 'blind' %}
      {% assign current_type = 'blinds' %}
    {% elsif collection_title_down contains 'shutter' %}
      {% assign current_type = 'shutters' %}
    {% elsif collection_title_down contains 'curtain' %}
      {% assign current_type = 'curtains' %}
    {% endif %}

    {% if current_type != '' %}
      {% assign current_type_down = current_type | downcase %}

      {% for sublink in main_menu %}
        {% assign title_down = sublink.title | downcase %}

        {% if title_down contains current_type_down %}
          {% for child in sublink.links %}
            {% for grandchild in child.links %}
              {% if grandchild.type == 'collection_link' %}
                {% assign temp_array = grandchild.object.handle | split: ',' %}
                {% assign slides = slides | concat: temp_array %}
              {% endif %}
            {% endfor %}
          {% endfor %}
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endif %}

  {% assign get_to_know_count = slides.size %}
{% endif %}

<p>Slides count: {{ slides.size }}</p>
<p>Collection handle: {{ collection.handle }}</p>

{% for category in linklists['main-menu'].links %}
  {% for sublink in category.links %}
    {% for child in sublink.links %}
      <p>
        {{ child.title }} |
        type: {{ child.type }} |
        url: {{ child.url }} |
        handle: {{ child.object.handle }}
      </p>
    {% endfor %}
  {% endfor %}
{% endfor %}


<section class="get-to-know" style="padding: 30px 0;">
  <div
    class="standard-container"
    style="background-color: {{ section.settings.background_color }}; max-widtH: calc(1520px - 80px); padding: 40px;"
  >
    <div class="get-to-know__head">
      <h2>{{ section.settings.title }}</h2>

      <div class="get-to-know__buttons">
        <button class="button button--square get-to-know__button--prev">←</button>
        <button class="button button--square get-to-know__button--next">→</button>
      </div>
    </div>

    <div class="get-to-know__slider">
      <div class="get-to-know__track">
        {% for s in slides %}
          {% assign collection_obj = collections[s] %}

          <div class="get-to-know__slide">
            <div class="get-to-know__slide__image">
              {% if collection_obj.image %}
                <img
                  src="{{ collection_obj.image | image_url }}"
                  alt="{{ collection_obj.metafields.custom.collection_page_title }}"
                >
              {% else %}
                <img src="{{ s.image | image_url }}" alt="{{ s.title }}">
              {% endif %}
            </div>

            <div class="get-to-know__slide__content">
              {% if collection_obj %}
                {% if collection_obj.metafields.custom.collection_page_title == blank %}
                  <h3>{{ collection_obj.title }}</h3>
                {% else %}
                  <h3>{{ collection_obj.metafields.custom.collection_page_title }}</h3>
                {% endif %}

                <p>{{ collection_obj.metafields.custom.short_description }}</p>

                <a href="{{ collection_obj.url }}">
                  View {{ collection_obj.metafields.custom.collection_page_title | default: collection_obj.title }}
                </a>
              {% else %}
                <h3>{{ s.title }}</h3>
                <p>{{ s.content }}</p>
                <a href="{{ s.link_url }}">{{ s.link_text }}</a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Get to Know",
  "settings": [
    {
      "type": "select",
      "id": "data",
      "label": "Content data",
      "options": [
        {
          "value": "general",
          "label": "General Data"
        },
        {
          "value": "collection",
          "label": "Collection Data"
        }
      ]
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#e8e9ea"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Get to know us"
    }
  ],
  "presets": [
    {
      "name": "Get to know"
    }
  ]
}
{% endschema %}

<script>
  document.querySelectorAll('.get-to-know').forEach((section) => {
    const slider = section.querySelector('.get-to-know__slider');
    const track = section.querySelector('.get-to-know__track');
    const slides = section.querySelectorAll('.get-to-know__slide');
    const prevBtn = section.querySelector('.get-to-know__button--prev');
    const nextBtn = section.querySelector('.get-to-know__button--next');

    if (!track || slides.length === 0) return;

    let currentTranslate = 0;
    let slideWidth = 0;
    let gap = 0;
    let maxTranslate = 0;

    function calculate() {
      slideWidth = slides[0].getBoundingClientRect().width;
      gap = parseInt(getComputedStyle(track).gap) || 0;

      const sliderWidth = slider.getBoundingClientRect().width;
      const trackWidth = track.scrollWidth;

      maxTranslate = Math.max(0, trackWidth - sliderWidth);

      currentTranslate = 0;
      updateSlider();
    }

    function updateSlider() {
      currentTranslate = Math.max(0, Math.min(currentTranslate, maxTranslate));
      track.style.transform = `translateX(-${currentTranslate}px)`;
    }

    nextBtn?.addEventListener('click', () => {
      if (currentTranslate < maxTranslate) {
        currentTranslate += slideWidth + gap;
        updateSlider();
      }
    });

    prevBtn?.addEventListener('click', () => {
      if (currentTranslate > 0) {
        currentTranslate -= slideWidth + gap;
        updateSlider();
      }
    });

    window.addEventListener('resize', calculate);
    window.addEventListener('load', calculate);
  });
</script>

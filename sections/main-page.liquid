<style>
  .return-to-blog {
    margin-top: 40px;
    text-align: center;
  }

  .return-to-blog a {
    color: #000;
    text-decoration: none;
    font-size: 18px;
  }

  .return-to-blog:hover {
    text-decoration: underline;
  }
</style>

<section class="main-page">
  <div class="standard-container">
    {% if template.name == 'page' %}
      <h1>
        {{ page.metafields.custom.on_page_title | default: page.title | escape }}
      </h1>
      <div>
        {{ page.content }}
      </div>

    {% elsif template.name == 'article' %}
      <h1>{{ article.title }}</h1>
      <div>{{ article.content }}</div>

      <div class="return-to-blog">
        <a href="{{ blog.url }}">← Return to {{ blog.title }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
